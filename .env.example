# Security Settings (REQUIRED in production)
GATEWAY_API_KEY=your-secure-api-key-here
GATEWAY_ENCRYPTION_KEY=your-fernet-encryption-key-here
GATEWAY_ALLOWED_IPS=

# Mode Settings
GATEWAY_PRODUCTION=false
GATEWAY_DEBUG=false

# Server Settings
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=5000

# MT5 Paths (Windows VPS only)
GATEWAY_MT5_BASE_PATH=C:\MT5Terminals
GATEWAY_MT5_TEMPLATE_PATH=C:\MT5Template

# Health Check & Restart Settings
GATEWAY_HEALTH_CHECK_INTERVAL=30
GATEWAY_MAX_RESTART_ATTEMPTS=3
GATEWAY_RESTART_COOLDOWN=60
